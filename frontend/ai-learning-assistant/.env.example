# Copy this to `.env` for local dev. In production, set these in the Vercel dashboard.

# Backend API base URL (no trailing slash)
# Local: http://localhost:8000
# Production: https://your-backend.onrender.com
VITE_API_BASE_URL=http://localhost:8000

# Speech app origin (optional)
VITE_SPEECH_APP_ORIGIN=https://live-ten-ebon.vercel.app


# AI Meeting Recorder — URL of the deployed standalone recorder app. The
# main project embeds it via iframe (same pattern as VITE_SPEECH_APP_ORIGIN
# above). Default points at the production deployment of SayanMazumder75
# /Deploy-Whisper.
VITE_MEETING_RECORDER_URL=https://deploy-whisper.vercel.app/
