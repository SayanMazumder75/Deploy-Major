# Copy this to `.env` for local dev. In production, set these in the Vercel dashboard.

# Backend API base URL (no trailing slash)
# Local: http://localhost:8000
# Production: https://your-backend.onrender.com
VITE_API_BASE_URL=http://localhost:8000

# Speech app origin (optional)
VITE_SPEECH_APP_ORIGIN=https://live-ten-ebon.vercel.app


# AI Meeting Recorder backend (Node + Express + Socket.io + Whisper). The
# backend lives in the standalone SayanMazumder75/Deploy-Whisper repo and is
# deployed to Render. Point this at your own deployment.
# Local: http://localhost:5000
# Production (example): https://deploy-whisper-api.onrender.com
VITE_MEETING_RECORDER_API_URL=http://localhost:5000
