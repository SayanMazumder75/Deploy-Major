# Copy this file to `.env` and fill in real values. Never commit `.env`.

# MongoDB Atlas connection string (include the database name in the path)
MONGODB_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/ailearning?retryWrites=true&w=majority&appName=AILearning

# Server (Render injects PORT in production; only set locally)
PORT=8000
NODE_ENV=development

# Auth
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRE=7d

# Uploads
#
# NOTE: the upload size limit is now hardcoded in backend/config/multer.js
# at 100 MB. The MAX_FILE_SIZE env var below is retained for backwards
# compatibility but is no longer read by the application — setting it here
# does not change the enforced limit. To change the limit, edit
# backend/config/multer.js.
MAX_FILE_SIZE=104857600

# Google Gemini (legacy var name — current code actually uses Groq below)
GEMINI_API_KEY=your_gemini_api_key

# Groq AI (powers flashcards, quizzes, chat, viva, summaries, etc.)
GROQ_API_KEY=your_primary_groq_api_key

# Groq AI — DEDICATED key for the AI Document Intelligence module.
#
# AI Document Intelligence runs a heavy multi-stage summarisation pipeline
# that can burn through the primary key's daily token budget very quickly
# on long PDFs. Setting a SECOND Groq key here isolates that load on its
# own quota so flashcards / quizzes / chat continue working even if the
# Intelligence module hits its limit (or vice versa).
#
# If GROQ_API_KEY2 is left unset, the Intelligence module silently falls
# back to GROQ_API_KEY — useful for local dev where you don't want to
# provision two keys.
GROQ_API_KEY2=your_secondary_groq_api_key

# Email (Gmail App Password recommended)
EMAIL_USER=you@example.com
EMAIL_PASS=your_gmail_app_password

# Frontend origin allowed by CORS (comma-separated for multiple)
# Local dev example: http://localhost:5173
# Production example: https://your-app.vercel.app
CLIENT_URL=http://localhost:5173
