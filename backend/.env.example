# Copy this file to `.env` and fill in real values. Never commit `.env`.

# MongoDB Atlas connection string (include the database name in the path)
MONGODB_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/ailearning?retryWrites=true&w=majority&appName=AILearning

# Server (Render injects PORT in production; only set locally)
PORT=8000
NODE_ENV=development

# Auth
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRE=7d

# Uploads
MAX_FILE_SIZE=10485760

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key

# Email (Gmail App Password recommended)
EMAIL_USER=you@example.com
EMAIL_PASS=your_gmail_app_password

# Frontend origin allowed by CORS (comma-separated for multiple)
# Local dev example: http://localhost:5173
# Production example: https://your-app.vercel.app
CLIENT_URL=http://localhost:5173
